{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stats Changes Schema",
  "type": "object",
  "properties": {
    "comparison_date": {
      "type": "string",
      "description": "The date or git reference against which current stats are compared"
    },
    "players": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "win_rate": { "type": "string", "pattern": "^[+-]\\d+(\\.\\d+)?%$" },
          "elo": { "type": "string", "pattern": "^[+-]\\d+$" },
          "ul_rank_de": { "type": "string" },
          "ul_rank_eu": { "type": "string" },
          "ul_points": { "type": "string", "pattern": "^[+-]\\d+$" },
          "mtga_rank_constructed": { "type": "string" },
          "mtga_rank_limited": { "type": "string" },
          "ul_win_rate": { "type": "string", "pattern": "^[+-]\\d+(\\.\\d+)?%$" },
          "elo_win_rate": { "type": "string", "pattern": "^[+-]\\d+(\\.\\d+)?%$" },
          "melee_win_rate": { "type": "string", "pattern": "^[+-]\\d+(\\.\\d+)?%$" },
          "topdeck_win_rate": { "type": "string", "pattern": "^[+-]\\d+(\\.\\d+)?%$" }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["comparison_date", "players"],
  "additionalProperties": false
}
